# Frontend Environment Variables
# For Vite to pick up environment variables, they must be prefixed with VITE_

# API Base URL for backend communication  
# Production default (works with Nginx proxy) - change for development
VITE_API_URL=/api

# WebSocket URL for real-time notifications
# Production default (works with Nginx proxy) - change for development  
VITE_WS_URL=/notifications

# For local development, use:
# VITE_API_URL=http://localhost:6767/api
# VITE_WS_URL=ws://localhost:6767/notifications
NODE_ENV=development