# Trade Finance Portal Backend Environment Configuration

# Server Configuration
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# Database Configuration
MONGODB_URI=mongodb://localhost:27017/tradeflow-nexus

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRE=30d

# Encryption Keys
ENCRYPTION_KEY=your-32-character-encryption-key-here

# Email Configuration (for notifications and 2FA)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=noreply@tradeflow.com
FROM_NAME=Trade Finance Portal

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_PATH=./uploads
ALLOWED_FILE_TYPES=pdf,xlsx,docx,png,jpg,jpeg

# Security Configuration
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX=1000
CORS_ORIGIN=http://localhost:5173
BCRYPT_ROUNDS=12

# Audit & Compliance
AUDIT_LOG_RETENTION_DAYS=2555
ENABLE_DETAILED_LOGGING=true
ENABLE_FINANCIAL_AUDIT=true

# External API Configuration (for real integrations)
BANK_API_URL=
BANK_API_KEY=
CREDIT_RATING_API_URL=
CREDIT_RATING_API_KEY=

# Monitoring & Alerts
ALERT_EMAIL_RECIPIENTS=ops@company.com,treasury@company.com
SLACK_WEBHOOK_URL=
ENABLE_REAL_TIME_ALERTS=true

# Business Rules
DEFAULT_RESERVE_PERCENTAGE=15
DEFAULT_PROCESSING_FEE=0.75
MAX_TRANSACTION_AMOUNT=10000000
DEFAULT_PAYMENT_TERMS=30